# terraform.tfvars - Replace with your actual values
# WARNING: Do not commit this file! Use it locally only or use GitHub secrets

aws_region     = "us-east-1"
app_name       = "oil-spill-app"
environment    = "prod"
instance_type  = "t3.medium"
instance_count = 1

# Database Configuration
db_instance_type       = "db.t3.small"
db_allocated_storage   = 50
db_multi_az            = true
db_backup_retention_days = 30
db_username            = "oil_spill_user"
db_password            = "CHANGE_ME_TO_SECURE_PASSWORD"

# S3 Configuration
s3_bucket_name = "oil-spill-app-uploads-UNIQUE_ID"

# SSH Access
ssh_allowed_cidrs = ["YOUR_IP/32"]
